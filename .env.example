# Copy this file to `.env` (which is gitignored) and fill in real values.
# Anything in .env is loaded into os.environ when the app starts.

# Tells `flask run` which file holds the app object.
FLASK_APP=app.py

# Turns on the debug reloader + interactive in-browser tracebacks.
# NEVER set this to 1 in production: the debugger lets anyone with the URL
# execute arbitrary Python on your server.
FLASK_DEBUG=1
